{
  "name": "n7technologies",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "dev:db": "wrangler d1 migrations apply n7-accounts --local --config n7-home-shell/wrangler.toml",
    "dev:app": "next dev -p 3000",
    "dev:shell": "wrangler dev --config n7-home-shell/wrangler.toml --port 3137 --var ORIGIN_URL:http://localhost:3000",
    "dev:full": "concurrently -k -n app,shell -c blue,magenta \"npm:dev:app\" \"npm:dev:shell\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "24.12.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "concurrently": "^10.0.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "wrangler": "^4.100.0"
  }
}
