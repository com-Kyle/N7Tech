# Backend env. Copy to backend/.env for local dev.
# When using `docker compose up`, these are read from docker-compose.yml instead.

# Required.
DATABASE_URL=postgres://n7technologies:n7technologies@localhost:5432/n7technologies?sslmode=disable

# Optional. Defaults shown.
PORT=8080
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_PUBLIC_DOMAIN=localhost:3000

# Required in production (APP_ENV=production); dev falls back to an insecure
# constant so the backend boots without it.
SESSION_SECRET=

# CIDR allow-list for X-Forwarded-For. Defaults to loopback only. Widen to your
# load balancer's CIDR in prod, e.g. TRUSTED_PROXIES=10.0.0.0/8
TRUSTED_PROXIES=127.0.0.1/32,::1/128
